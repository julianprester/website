{
  "name": "website",
  "version": "1.0.0",
  "description": "Julian Prester's personal website — built with Eleventy, Tailwind CSS, and Alpine.js",
  "scripts": {
    "clean": "rm -rf public",
    "start": "eleventy --serve & postcss src/styles/*.css --dir public/css --watch",
    "build": "ELEVENTY_PRODUCTION=true eleventy && NODE_ENV=production postcss src/styles/*.css --dir public/css",
    "grab": "node util/grab_articles.js",
    "schedule": "node util/schedule_articles.js",
    "syndicate": "node util/syndicate_articles.js",
    "status": "node util/status_update.js"
  },
  "keywords": [],
  "author": "Julian Prester",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-navigation": "^1.0.5",
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@octokit/rest": "^22.0.1",
    "autoprefixer": "^10.5.0",
    "axios": "^1.15.2",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.0",
    "openai": "^4.104.0",
    "postcss": "^8.5.13",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^3.4.19",
    "turndown": "^7.2.4",
    "twitter-api-v2": "^1.29.0"
  },
  "dependencies": {
    "sharp": "^0.34.5"
  }
}
