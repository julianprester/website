{
  "name": "website",
  "version": "1.0.0",
  "description": "Julian Prester's personal website — built with Eleventy and Tailwind CSS",
  "homepage": "https://julianprester.com",
  "repository": "github:julianprester/website",
  "bugs": "https://github.com/julianprester/website/issues",
  "scripts": {
    "clean": "rm -rf public",
    "start": "eleventy --serve & tailwindcss -i src/styles/tailwind.css -o public/css/tailwind.css --watch",
    "build": "ELEVENTY_PRODUCTION=true eleventy && tailwindcss -i src/styles/tailwind.css -o public/css/tailwind.css --minify",
    "format": "prettier --write 'src/**/*.{md,js,json,css}' '.eleventy.js'",
    "format:check": "prettier --check 'src/**/*.{md,js,json,css}' '.eleventy.js'"
  },
  "keywords": [],
  "author": "Julian Prester",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-navigation": "^1.0.5",
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "luxon": "^3.7.2",
    "markdown-it": "^14.1.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4"
  }
}
