---
pagination:
  data: webfinger
  size: 1
  alias: user
permalink: "webfinger/{{ user.username | slug }}.json"
eleventyExcludeFromCollections: true
---
{
  "subject": "acct:{{ user.username }}@{{ user.domain }}",
  "aliases": ["mailto:{{ user.email }}"],
  "links": [
    {
      "rel": "http://openid.net/specs/connect/1.0/issuer",
      "href": "{{ user.issuer }}"
    }
  ]
}
